# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://pawpal:pawpal123@localhost:5432/pawpal?schema=public"

# JWT
JWT_SECRET="pawpal-super-secret-key-change-in-production-2026"
JWT_EXPIRES_IN="7d"

# LLM (DeepSeek / OpenAI compatible) — legacy one-shot consult endpoint
LLM_API_KEY="your-deepseek-api-key-here"
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_MODEL="deepseek-chat"

# DeepSeek (multi-turn chat endpoint) — alias for LLM_API_KEY/LLM_BASE_URL
# Either set of vars works; DEEPSEEK_* takes precedence if both are set.
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Encryption (AES-256)
ENCRYPTION_KEY="pawpal-encryption-key-32bytes-changeme!!"

# File Upload
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=52428800

# Rate Limiting
AI_RATE_LIMIT_PER_HOUR=20
AUTH_RATE_LIMIT_PER_15MIN=10

# CORS
CORS_ORIGIN="http://localhost:5173"

# Supabase (for production cloud storage)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb-secret-xxxxx
# SUPABASE_STORAGE_BUCKET=uploads
